{
  "name": "genspark-openclaw",
  "version": "0.1.0",
  "description": "Unofficial open-source TypeScript client for the GenSpark.ai API — reverse-engineered, feature-rich, and community-driven.",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test",
    "example": "tsx examples/basic.ts"
  },
  "keywords": [
    "genspark",
    "genspark-ai",
    "ai",
    "llm",
    "api-client",
    "typescript",
    "unofficial",
    "reverse-engineered",
    "openclaw"
  ],
  "author": "openclaw contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openclaw/genspark.ai-openclaw.git"
  },
  "bugs": {
    "url": "https://github.com/openclaw/genspark.ai-openclaw/issues"
  },
  "homepage": "https://github.com/openclaw/genspark.ai-openclaw#readme",
  "dependencies": {
    "eventsource-parser": "^2.0.1",
    "node-fetch": "^3.3.2",
    "undici": "^6.11.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "@typescript-eslint/parser": "^7.7.1",
    "@vitest/coverage-v8": "^1.5.2",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "tsup": "^8.0.2",
    "tsx": "^4.9.3",
    "typescript": "^5.4.5",
    "vitest": "^1.5.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
