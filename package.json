{
  "name": "genspark-openclaw",
  "version": "1.0.0",
  "description": "Open-source browser extension to unlock unrestricted access to genspark.ai — bypass paywalls, rate limits, and authentication walls.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "webpack --config webpack.config.js --watch --mode development",
    "build": "webpack --config webpack.config.js --mode production",
    "build:chrome": "cross-env BROWSER=chrome npm run build",
    "build:firefox": "cross-env BROWSER=firefox npm run build",
    "build:all": "npm run build:chrome && npm run build:firefox",
    "lint": "eslint src/**/*.{js,ts} --fix",
    "format": "prettier --write 'src/**/*.{js,ts,json}'",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "zip:chrome": "cd dist/chrome && zip -r ../../releases/genspark-openclaw-chrome.zip .",
    "zip:firefox": "cd dist/firefox && zip -r ../../releases/genspark-openclaw-firefox.zip .",
    "release": "npm run build:all && npm run zip:chrome && npm run zip:firefox",
    "clean": "rimraf dist releases"
  },
  "keywords": [
    "genspark",
    "browser-extension",
    "ai",
    "open-access",
    "chrome-extension",
    "firefox-addon",
    "openclaw"
  ],
  "author": "openclaw contributors",
  "license": "MIT",
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/firefox-webext-browser": "^120.0.0",
    "@types/jest": "^29.5.12",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "copy-webpack-plugin": "^12.0.2",
    "cross-env": "^7.0.3",
    "css-loader": "^6.10.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "html-webpack-plugin": "^5.6.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "mini-css-extract-plugin": "^2.8.1",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "style-loader": "^3.3.4",
    "ts-jest": "^29.1.2",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.2",
    "webpack": "^5.90.3",
    "webpack-cli": "^5.1.4",
    "zip-webpack-plugin": "^4.0.1"
  },
  "dependencies": {
    "webextension-polyfill": "^0.10.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
