{
  "manifest_version": 2,
  "name": "GenSpark OpenClaw",
  "version": "1.0.0",
  "description": "Open-source extension that unlocks full access to genspark.ai — no limits, no paywalls, no walls.",
  "homepage_url": "https://github.com/openclaw/genspark.ai-openclaw",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    },
    "default_title": "GenSpark OpenClaw"
  },

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "content_scripts": [
    {
      "matches": ["*://*.genspark.ai/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],

  "permissions": [
    "storage",
    "tabs",
    "cookies",
    "webRequest",
    "webRequestBlocking",
    "notifications",
    "*://*.genspark.ai/*",
    "*://api.genspark.ai/*"
  ],

  "web_accessible_resources": ["icons/*"],

  "browser_specific_settings": {
    "gecko": {
      "id": "genspark-openclaw@openclaw.dev",
      "strict_min_version": "109.0"
    }
  }
}
